{
  "name": "git-fs",
  "version": "2.0.0",
  "description": "Virtual filesystem over a bare git object store (TypeScript port).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "git-fs": "dist/cli.js",
    "git-fs-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "dev:mcp": "tsx src/mcp.ts",
    "dev:cli": "tsx src/cli.ts",
    "test": "node --import tsx --test test/store.test.ts",
    "bench": "tsx bench/session-500.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "diff": "^5.2.0",
    "node-diff3": "^3.1.2",
    "isomorphic-git": "^1.27.0",
    "picomatch": "^4.0.2",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^20.11.0",
    "@types/picomatch": "^3.0.1",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.24.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
